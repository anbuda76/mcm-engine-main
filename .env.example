# ─── Flask ──────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=cambia-questa-chiave-sicura-almeno-32-caratteri

# ─── Database — Supabase PostgreSQL ─────────────────────────────────────────
# Copia la "Connection string" dalla dashboard Supabase:
#   Project Settings → Database → Connection string → URI
# Formato: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# In produzione (Railway) imposta DATABASE_URL come variabile d'ambiente nel
# dashboard Railway — NON commitare la password nel codice.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Admin di default (creato automaticamente al primo avvio) ────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-questa-password-sicura

# ─── Dati Excel ──────────────────────────────────────────────────────────────
# Percorso assoluto o relativo alla root del progetto.
# Su Railway: monta un volume e imposta il path assoluto del mount point.
#   Esempio volume Railway montato in /data:  DATA_RAW_PATH=/data
DATA_RAW_PATH=data_raw
CACHE_TTL_HOURS=8

# ─── AI / Ollama (opzionale) ─────────────────────────────────────────────────
# Se non configurato, l'AI assistant non sarà disponibile in produzione.
# Puoi deployare un servizio Ollama separato su Railway e puntare qui.
# OLLAMA_HOST=http://ollama-service:11434
